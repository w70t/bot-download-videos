# ═══════════════════════════════════════════════════════════
# Telegram Bot Configuration - إعداد البوت
# ═══════════════════════════════════════════════════════════
# احصل على هذه القيم من: https://my.telegram.org/apps
PYROGRAM_API_ID=12345678
PYROGRAM_API_HASH=0123456789abcdef0123456789abcdef

# احصل على Token من: @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ═══════════════════════════════════════════════════════════
# Admin Configuration - معلومات المدير
# ═══════════════════════════════════════════════════════════
# ضع Telegram ID الخاص بك (رقمك التعريفي)
ADMIN_ID=123456789

# معرّف Binance Pay لاستقبال المدفوعات (اختياري)
BINANCE_PAY_ID=

# معرّف حساب الدعم على تيليجرام بدون @ (اختياري)
SUPPORT_USERNAME=

# ═══════════════════════════════════════════════════════════
# PostgreSQL Database - قاعدة البيانات
# ═══════════════════════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telegram_bot
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=your_secure_password_here

# حجم مجمّع اتصالات قاعدة البيانات (اختياري)
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=10

# ═══════════════════════════════════════════════════════════
# تحسين سرعة التحميل - Download speed (اختياري)
# ═══════════════════════════════════════════════════════════
# عدد أجزاء التحميل المتوازية (أسرع ليوتيوب). تجنّب القيم العالية جداً (>16)
YTDLP_CONCURRENT_FRAGMENTS=4

# عملاء يوتيوب مفصولين بفاصلة (أقل = أسرع استخراج). اتركه فارغاً للافتراضي
# YT_PLAYER_CLIENTS=default,web_safari,mweb

# ═══════════════════════════════════════════════════════════
# Channels Configuration - قنوات التسجيل (اختياري)
# ═══════════════════════════════════════════════════════════
# قناة سجلات تحميل الفيديوهات (اختياري - اتركها فارغة إذا لم تحتاجها)
LOG_CHANNEL_ID=-1001234567890

# قناة سجلات الأخطاء (اختياري - اتركها فارغة إذا لم تحتاجها)
ERROR_LOG_CHANNEL_ID=-1001234567890

# قناة إشعارات الأعضاء الجدد (اختياري - اتركها فارغة إذا لم تحتاجها)
NEW_MEMBERS_CHANNEL_ID=-1001234567890

# ملاحظة: الكاش يعيد استخدام نسخة قناة السجلات (LOG_CHANNEL_ID) كمرجع دائم،
# فلا حاجة لقناة أرشيف منفصلة.

# قناة إجابات الاستبيان: تصل فيها إجابات الأعضاء (الجنس + سؤالك) مع زر رد
# مباشر للعضو (اختياري - أضف البوت كمشرف فيها)
SURVEY_CHANNEL_ID=-1001234567890

# قناة النسخ الاحتياطي: تُرفع فيها نسخة كاملة من بيانات الأعضاء (JSON) تلقائياً
# ويدوياً، وتُسترجَع منها عند تعطّل الجهاز (اختياري - أضف البوت كمشرف)
BACKUP_CHANNEL_ID=-1001234567890

# مدة النسخ التلقائي بالساعات (0 لتعطيله، الافتراضي 12)
AUTO_BACKUP_HOURS=12

# كل دعوة ناجحة تزيد الحد اليومي للداعي بهذا المقدار (دائماً، الافتراضي 1)
REFERRAL_BONUS=1

# كل دعوة ناجحة تزيد أيضاً حدّ مدة الفيديو المسموحة للداعي بهذا العدد من الدقائق
# (دائماً، الافتراضي 5). مثال: الأساس 10 دقائق + دعوة = 15، + دعوتان = 20... وهكذا
REFERRAL_MINUTES=5

# أقصى عدد صور تُحمَّل من منشور إنستغرام/تيك توك المصوّر (كاروسيل/سلايدشو، الافتراضي 30)
GALLERY_DL_MAX_IMAGES=30

# عدد أيام الخمول لاعتبار العضو غير نشط في زر التذكير (الافتراضي 7)
REMINDER_INACTIVE_DAYS=7
